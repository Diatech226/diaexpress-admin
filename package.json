{
  "name": "diaexpress-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3201",
    "dev:clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true });\" && next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "echo \"No tests specified\"",
    "deps:reset": "node -e \"require('fs').rmSync('node_modules', { recursive: true, force: true }); require('fs').rmSync('.next', { recursive: true, force: true });\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.4",
    "@clerk/nextjs": "^6.39.1",
    "client-only": "0.0.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "14.2.25",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "styled-jsx": "5.1.1",
    "@dia/ui": "workspace:*",
    "@dia/shared": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.25",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "styled-jsx": "5.1.1",
    "client-only": "0.0.1"
  }
