# ==================================================
# DiaExpress Admin v2 — .env.example
# Scope: apps/diaexpress-adminv2
# ==================================================

# APP
NODE_ENV=development
PORT=3011

# ==================================================
# API URLS
# ==================================================
# Canonical backend base URL for adminv2
NEXT_PUBLIC_API_BASE_URL=http://localhost:5010

# Compatibility aliases
NEXT_PUBLIC_ADMIN_API_BASE_URL=http://localhost:5010/api/v1/admin
NEXT_PUBLIC_LOGISTICS_API_BASE_URL=http://localhost:5010

# diaPay admin endpoints
NEXT_PUBLIC_DIAPAY_ADMIN_API_BASE_URL=http://localhost:5010/api/v1/admin
NEXT_PUBLIC_ENABLE_DIAPAY=true

# Optional dev-only fallback token (never use in production)
NEXT_PUBLIC_ADMIN_BEARER_TOKEN=

# ==================================================
# CLERK (ADMIN AUTH)
# ==================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_key
CLERK_SECRET_KEY=sk_test_xxx

# Canonical template read by current auth bridge
NEXT_PUBLIC_BACKEND_JWT_TEMPLATE=diaexpress-backend

# Legacy aliases still read in compatibility mode
NEXT_PUBLIC_DIAEXPRESS_CLERK_JWT_TEMPLATE=diaexpress-backend
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=diaexpress-backend
NEXT_PUBLIC_CLERK_TEMPLATE=diaexpress-backend

# Server-side aliases used by admin auth/api helpers
BACKEND_URL=http://localhost:5010
ADMIN_API_BASE_URL=http://localhost:5010/api/v1/admin
BACKEND_JWT_TEMPLATE=diaexpress-backend
DIAEXPRESS_CLERK_JWT_TEMPLATE=diaexpress-backend
CLERK_JWT_TEMPLATE=diaexpress-backend
CLERK_TEMPLATE=diaexpress-backend

# CORS / cookies / session notes
NEXT_PUBLIC_COOKIE_AUTH_ENABLED=false
NEXT_PUBLIC_AUTH_SOURCE=clerk-backend-bridge
NEXT_PUBLIC_ADMIN_REQUIRED_ROLE=admin

# MongoDB is configured on the API, not in this frontend.
